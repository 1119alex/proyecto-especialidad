# ====================================
# GITIGNORE GLOBAL - Monorepo LogiTrack
# ====================================
# Este archivo ignora elementos comunes a todos los proyectos del monorepo
# Cada subproyecto tiene su propio .gitignore específico

# ====================================
# Variables de Entorno (MUY IMPORTANTE)
# ====================================
**/.env
**/.env.local
**/.env.development.local
**/.env.test.local
**/.env.production.local
.env
.env.local
.env.*.local

# Mantener archivos .env.example como plantillas
!**/.env.example

# ====================================
# Archivos del Sistema Operativo
# ====================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# ====================================
# IDEs y Editores
# ====================================
# VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# IntelliJ IDEA
.idea/
*.iml
*.ipr
*.iws
out/

# Eclipse
.project
.classpath
.settings/

# ====================================
# Node Modules (Backend y Frontend Web)
# ====================================
**/node_modules/
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# ====================================
# Logs
# ====================================
logs
*.log
pids
*.pid
*.seed
*.pid.lock

# ====================================
# Build y Distribución
# ====================================
dist/
build/
out/
.cache/

# ====================================
# Archivos temporales
# ====================================
*.tmp
*.temp
*.swp
*.swo
*~
nul

# ====================================
# Archivos de Base de Datos
# ====================================
# Ignorar dumps de bases de datos locales
*.sql.backup
*.db.backup
local_*.sql

# Mantener el schema principal
!database_schema.sql

# ====================================
# Archivos de Configuración Sensibles
# ====================================
# Credenciales de Firebase
firebase-adminsdk-*.json
google-services.json
GoogleService-Info.plist

# Certificados y claves
*.pem
*.key
*.cert
*.p12
*.jks
*.keystore

# ====================================
# Coverage y Testing
# ====================================
coverage/
*.lcov
.nyc_output/
test-results/
junit.xml

# ====================================
# Otros
# ====================================
.terraform/
*.tfstate
*.tfstate.backup
