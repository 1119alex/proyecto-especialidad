# ====================================
# FRONTEND WEB - React + Vite .gitignore
# ====================================

# ====================================
# Dependencies
# ====================================
node_modules/
package-lock.json

# ====================================
# Environment Variables
# ====================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Mantener .env.example
!.env.example

# ====================================
# Build Output (Vite)
# ====================================
dist/
dist-ssr/
*.local

# ====================================
# Build Output (Create React App - Legacy)
# ====================================
build/

# ====================================
# Testing
# ====================================
coverage/

# ====================================
# Logs
# ====================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ====================================
# Editor directories and files
# ====================================
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ====================================
# Vite
# ====================================
.vite/

# ====================================
# Misc
# ====================================
.pnp
.pnp.js
