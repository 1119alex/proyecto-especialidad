# ====================================
# BACKEND - NestJS .gitignore
# ====================================

# ====================================
# Dependencies
# ====================================
node_modules/
package-lock.json

# ====================================
# Environment Variables
# ====================================
.env
.env.local
.env.*.local

# Mantener .env.example
!.env.example

# ====================================
# Build Output
# ====================================
dist/
build/
*.tsbuildinfo

# ====================================
# Logs
# ====================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# ====================================
# Testing
# ====================================
coverage/
.nyc_output/
test-results/

# ====================================
# IDE
# ====================================
.vscode/
.idea/
*.swp
*.swo
*~

# ====================================
# OS
# ====================================
.DS_Store
Thumbs.db

# ====================================
# TypeORM
# ====================================
ormconfig.json

# ====================================
# Uploads (si hay archivos subidos)
# ====================================
uploads/
temp/

# ====================================
# Firebase Admin SDK
# ====================================
firebase-adminsdk-*.json
